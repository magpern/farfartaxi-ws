# Copy to `.env` and adjust. Docker Compose reads `.env` from this directory for variable substitution.
# For local `mvn spring-boot:run`, export these or use your IDE env config (Spring does not load `.env` by itself).

# --- Server ---
SERVER_PORT=8080

# --- Database (defaults match application.properties) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/farfartaxi
SPRING_DATASOURCE_USERNAME=taxi_mgmt
SPRING_DATASOURCE_PASSWORD=change-this-db-password

# --- JWT ---
APP_JWT_SECRET=change-this-jwt-secret-to-a-long-random-value
APP_JWT_EXPIRATION_MINUTES=720

# --- Bootstrap admin (password login) ---
FARFARTAXI_ADMIN_EMAIL=admin@farfartaxi.local
FARFARTAXI_ADMIN_PASSWORD=ChangeMeNow123!
FARFARTAXI_ADMIN_NAME=Farfar Admin

# --- Google Sign-In (Web client ID from Google Cloud Console → APIs & Services → Credentials) ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Optional: only if you add server-side OAuth (authorization code). Not used for the current browser ID-token flow.
# GOOGLE_CLIENT_SECRET=

# --- Push (Web Push / VAPID) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@farfartaxi.local

# --- Misc ---
APP_ETA_DEFAULT_KMH=35

# --- docker-compose.rpi.yml (GHCR image prefix, lowercase GitHub username or org) ---
# GHCR_OWNER=magpern
